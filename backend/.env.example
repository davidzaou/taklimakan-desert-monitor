# ─── Google Earth Engine Configuration ───
# Uncomment and set these to enable real satellite data.
# Without these, the app runs in DEMO mode with simulated data.

# Option 1: Service account JSON key file (recommended for production)
# GEE_SERVICE_ACCOUNT_KEY=/path/to/your-service-account-key.json
# GEE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Option 2: GCP project with Application Default Credentials
# Run `earthengine authenticate` first, then set:
# GEE_PROJECT=your-gcp-project-id

# ─── CORS ───
# Comma-separated list of allowed origins (default: http://localhost:5173)
# In production, frontend is served from same origin, so only needed for dev
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Server ───
# PORT=8000

# ─── How to get GEE credentials ───
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or use existing one)
# 3. Enable the Earth Engine API: https://console.cloud.google.com/apis/library/earthengine.googleapis.com
# 4. Register your project at: https://code.earthengine.google.com/register
# 5. Create a service account:
#    - Go to IAM & Admin > Service Accounts
#    - Create service account, download JSON key
#    - Set GEE_SERVICE_ACCOUNT_KEY to the JSON file path
# 6. Restart the backend server
